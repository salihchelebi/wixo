# Netlify Function admin auth için kullanıcı adı
ADMIN_USER_NAME=

# Netlify Function admin auth için parola (plain text, function tarafında hashlenir)
ADMIN_PASSWORD=

# Supabase proje URL'i (frontend public config ve function erişimi için)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role key (yalnızca Netlify Functions tarafında kullanılmalı)
SUPABASE_SERVICE_ROLE_KEY=

# Netlify build sırasında lite akış route'larını aktif eder
VITE_NETLIFY_LITE=true
