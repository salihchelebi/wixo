# Wixoo Function admin auth için kullanıcı adı
ADMIN_USER_NAME=

# Wixoo Function admin auth için parola (plain text, function tarafında hashlenir)
ADMIN_PASSWORD=

# Wixoo Function admin auth için e-posta (preview local login fallback için kullanılır)
ADMIN_EMAIL=

# Supabase proje URL'i (frontend public config ve function erişimi için)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key (UI tarafında kullanılabilir)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Supabase service role key (yalnızca server-side function tarafında kullanılmalı)
SUPABASE_SERVICE_ROLE_KEY=

# Flowise UI'nin çağıracağı backend host'u (örn: http://localhost:3000 veya https://flowise-api.example.com)
VITE_API_BASE_URL=

# Netlify function proxy upstream host'u (VITE_API_BASE_URL ile aynı host önerilir)
FLOWISE_API_BASE_URL=
# Boş bırakılırsa proxy /api/v1/settings için openSource fallback döndürür

# Netlify Lite arayüzünü devre dışı bırak (saf Flowise UI için false)
VITE_NETLIFY_LITE=false
